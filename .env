# ═══════════════════════════════════════════════
# TASKFLOW — Variáveis de Ambiente
# ───────────────────────────────────────────────
# DESENVOLVIMENTO LOCAL:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores abaixo
#   3. O .env NUNCA deve ser enviado ao GitHub!
#
# PRODUCAO (Render/Railway):
#   Configure essas variáveis no painel do serviço
#   em Environment Variables — não use .env lá.
# ═══════════════════════════════════════════════

# ── OBRIGATÓRIO em produção ──────────────────
# Gere uma chave aleatória segura. Exemplo pelo terminal:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=d775675ded9a423aad689348efaa87461b35e4112a2830f384fc23de4d25ad2a

# ── BANCO DE DADOS ───────────────────────────
# Desenvolvimento local (SQLite — sem configuração):
DATABASE_URL=sqlite:///taskflow.db

# Produção com Supabase (PostgreSQL):
# Vá em: Supabase → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:Arerlchce1!@db.indetrbyrnlggqwuhbae.supabase.co:5432/postgres

# Produção com Railway (ele preenche automaticamente):
# 
DATABASE_URL=  <-- Railway injeta isso sozinho

# ── AMBIENTE ─────────────────────────────────
# development = modo debug, sem HTTPS obrigatório
# production  = modo seguro, cookies HTTPS, sem debug
FLASK_ENV=development
FLASK_DEBUG=1
